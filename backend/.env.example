# Application
NODE_ENV=development
APP_NAME=PartnerLedger OS Backend
APP_PORT=4000
APP_GLOBAL_PREFIX=api
FRONTEND_ORIGIN=http://localhost:3000
WS_CORS_ORIGIN=http://localhost:3000

# Supabase / PostgreSQL
# DATABASE_URL should use the Supabase pooled connection string.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# DIRECT_URL should use the direct Postgres connection string for Prisma migrations.
DIRECT_URL=postgresql://postgres.your-project-ref:your-password@db.your-project-ref.supabase.co:5432/postgres

# JWT
JWT_ACCESS_SECRET=replace-this-with-a-32-character-minimum-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-this-with-another-32-character-minimum-secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
